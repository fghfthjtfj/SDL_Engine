#version 450
layout(local_size_x = 1) in;

layout(set=0, binding=0) readonly buffer CountBuf  { uint counts[];  };
layout(set=1, binding=0)          buffer OffsetBuf { uint offsets[]; };

void main() {
    uint sum = 0;
    for (uint i = 0; i < uint(offsets.length()); i++) {
        offsets[i] = sum; // это и есть зануление первого элемента + запись offset
        sum += counts[1 + i];
    }
}